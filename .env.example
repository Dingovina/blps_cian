# Переменные окружения для подключения к PostgreSQL
# Скопируйте в .env и подставьте свои значения или экспортируйте в shell:
#   export DB_HOST=localhost
#   export DB_PORT=5432
#   export DB_NAME=cian
#   export DB_USERNAME=postgres
#   export DB_PASSWORD=your_password
#   export SERVER_PORT=8080
#   export DB_SCHEMA=...
# На helios/studs таблицы создаются в схеме пользователя — укажите DB_SCHEMA=s408867 (ваш логин).
#
# Запуск: set -a && source .env && set +a && java -jar cian.jar

SERVER_PORT=8080
DB_HOST=pg
DB_PORT=5432
DB_NAME=studs
DB_USERNAME=s408867
DB_PASSWORD=
DB_SCHEMA=s408867
